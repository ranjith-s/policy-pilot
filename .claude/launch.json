{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "streamlit-ui",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "app/app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    },
    {
      "name": "haqdar-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "api.server:app", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "haqdar-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "port": 5173
    }
  ]
}
